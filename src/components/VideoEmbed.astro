---
/**
 * Inserta un vídeo a partir de una URL.
 * Soporta YouTube, Vimeo y ficheros de vídeo directos (mp4/webm).
 */
interface Props {
  url: string;
  titulo?: string;
}
const { url, titulo = 'Vídeo' } = Astro.props;

function parseVideo(raw: string): { tipo: 'youtube' | 'vimeo' | 'file'; src: string } {
  try {
    const u = new URL(raw);
    const host = u.hostname.replace('www.', '');

    if (host === 'youtube.com' || host === 'm.youtube.com') {
      const id = u.searchParams.get('v');
      if (id) return { tipo: 'youtube', src: `https://www.youtube-nocookie.com/embed/${id}` };
    }
    if (host === 'youtu.be') {
      const id = u.pathname.slice(1);
      if (id) return { tipo: 'youtube', src: `https://www.youtube-nocookie.com/embed/${id}` };
    }
    if (host === 'vimeo.com') {
      const id = u.pathname.split('/').filter(Boolean)[0];
      if (id) return { tipo: 'vimeo', src: `https://player.vimeo.com/video/${id}` };
    }
  } catch {
    /* url malformada: se trata como fichero */
  }
  return { tipo: 'file', src: raw };
}

const { tipo, src } = parseVideo(url);
---

<div class="video">
  {
    tipo === 'file' ? (
      <video controls preload="metadata" src={src}>
        <track kind="captions" />
      </video>
    ) : (
      <iframe
        src={src}
        title={titulo}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      />
    )
  }
</div>

<style>
  .video {
    position: relative;
    aspect-ratio: 16 / 9;
    background: #000;
    border-radius: var(--radio);
    overflow: hidden;
    margin-block: 1.5rem;
  }
  .video iframe,
  .video video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
