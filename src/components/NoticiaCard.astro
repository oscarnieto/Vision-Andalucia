---
import type { Noticia } from '../lib/noticias';
import { sectorLabel } from '../lib/sectors';

interface Props {
  noticia: Noticia;
}

const { noticia } = Astro.props;
const { data, slug } = noticia;
const url = `/noticia/${slug}/`;
const etiqueta = (data.categoria ?? sectorLabel(data.sector)).toUpperCase();
const imagen = data.imagen ?? '/uploads/placeholder.svg';
---

<a class="card" href={url}>
  <div class="card__media">
    <img src={imagen} alt={data.imagenAlt} loading="lazy" />
  </div>
  <div class="card__grad" aria-hidden="true"></div>
  <div class="card__cuerpo">
    <span class="card__cat">{etiqueta}</span>
    <h3 class="card__titulo" title={data.titulo}>{data.titulo}</h3>
    <span class="card__autor">{data.autor}</span>
  </div>
</a>

<style>
  .card {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--color-card);
    color: #fff;
    isolation: isolate;
  }
  .card__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      transform 0.6s ease-in-out,
      filter 0.6s ease-in-out;
  }
  .card__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--color-card);
  }
  .card__grad {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 38%,
      rgba(0, 0, 0, 0.87) 91%
    );
  }
  .card__cuerpo {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 2;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .card__cat {
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    color: var(--color-acento);
  }
  .card__titulo {
    font-family: var(--fuente-titulos);
    font-weight: 400;
    font-size: 1.35rem;
    line-height: 1.05;
    margin: 0;
    color: #fff;
    /* Máximo 2 líneas; el resto se recorta con "…" */
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
  }
  .card__autor {
    font-weight: 500;
    font-size: 0.8rem;
    color: #fff;
  }

  /* ---- Efecto hover: solo se amplía la imagen de fondo ---- */
  .card:hover .card__media img,
  .card:focus-visible .card__media img {
    transform: scale(1.12);
    filter: brightness(0.72);
  }
  /* Indicador de foco por teclado (accesibilidad), sin sombra */
  .card:focus-visible {
    outline: 3px solid var(--color-acento);
    outline-offset: 2px;
  }
</style>
