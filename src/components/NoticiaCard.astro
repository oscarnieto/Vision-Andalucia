---
import type { Noticia } from '../lib/noticias';
import { sectorLabel } from '../lib/sectors';
import FechaNoticia from './FechaNoticia.astro';

interface Props {
  noticia: Noticia;
  /** La primera tarjeta de un listado puede destacarse visualmente. */
  destacado?: boolean;
}

const { noticia, destacado = false } = Astro.props;
const { data, slug } = noticia;
const url = `/noticia/${slug}/`;
---

<article class:list={['tarjeta', { 'tarjeta--destacado': destacado }]}>
  <a href={url} class="tarjeta__media" aria-hidden="true" tabindex="-1">
    {
      data.imagen ? (
        <img src={data.imagen} alt={data.imagenAlt} loading="lazy" />
      ) : (
        <div class="tarjeta__placeholder">Vision Andalucia</div>
      )
    }
  </a>
  <div class="tarjeta__cuerpo">
    <a href={`/sector/${data.sector}/`} class="tarjeta__sector">
      {sectorLabel(data.sector)}
    </a>
    <h3 class="tarjeta__titulo">
      <a href={url}>{data.titulo}</a>
    </h3>
    {destacado && <p class="tarjeta__resumen">{data.resumen}</p>}
    <FechaNoticia fecha={data.fecha} />
  </div>
</article>

<style>
  .tarjeta {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-borde);
    border-radius: var(--radio);
    overflow: hidden;
    background: var(--color-fondo);
    transition: box-shadow 0.15s ease;
  }
  .tarjeta:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }
  .tarjeta__media {
    display: block;
    aspect-ratio: 16 / 9;
    background: var(--color-superficie);
    overflow: hidden;
  }
  .tarjeta__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tarjeta__placeholder {
    display: grid;
    place-items: center;
    height: 100%;
    color: var(--color-texto-suave);
    font-family: var(--fuente-titulos);
    background: var(--color-superficie);
  }
  .tarjeta__cuerpo {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .tarjeta__sector {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primario);
  }
  .tarjeta__sector:hover {
    text-decoration: none;
    color: var(--color-primario-oscuro);
  }
  .tarjeta__titulo {
    font-size: 1.1rem;
    margin: 0;
  }
  .tarjeta__titulo a {
    color: var(--color-texto);
  }
  .tarjeta__titulo a:hover {
    color: var(--color-primario);
    text-decoration: none;
  }
  .tarjeta__resumen {
    color: var(--color-texto-suave);
    margin: 0;
    font-size: 0.95rem;
  }

  /* Variante destacada: ocupa el ancho y coloca media + texto en fila */
  .tarjeta--destacado {
    grid-column: 1 / -1;
  }
  @media (min-width: 700px) {
    .tarjeta--destacado {
      flex-direction: row;
    }
    .tarjeta--destacado .tarjeta__media {
      flex: 1 1 55%;
      aspect-ratio: 16 / 9;
    }
    .tarjeta--destacado .tarjeta__cuerpo {
      flex: 1 1 45%;
      justify-content: center;
      padding: 1.5rem;
    }
    .tarjeta--destacado .tarjeta__titulo {
      font-size: 1.6rem;
    }
  }
</style>
