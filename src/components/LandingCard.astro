---
import type { CollectionEntry } from 'astro:content';

interface Props {
  pagina: CollectionEntry<'paginas'>;
}

const { pagina } = Astro.props;
const { data, slug } = pagina;
const url = `/informe/${slug}/`;
const imagen = data.heroImagen ?? '/uploads/placeholder.svg';
---

<a class="landing" href={url}>
  <div class="landing__media">
    <img src={imagen} alt={data.heroImagenAlt} loading="lazy" />
  </div>
  <div class="landing__grad" aria-hidden="true"></div>
  <div class="landing__cuerpo">
    {data.etiqueta && <span class="landing__badge">{data.etiqueta}</span>}
    <h3 class="landing__titulo">{data.titular}</h3>
    {data.autor && <span class="landing__autor">{data.autor}</span>}
  </div>
</a>

<style>
  .landing {
    position: relative;
    display: block;
    width: 100%;
    height: clamp(340px, 34vw, 460px);
    overflow: hidden;
    background: var(--color-card);
    color: #fff;
    isolation: isolate;
  }
  .landing__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .landing__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      transform 0.6s ease-in-out,
      filter 0.6s ease-in-out;
  }
  .landing__grad {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.9) 0%,
      rgba(0, 0, 0, 0.45) 26%,
      rgba(0, 0, 0, 0) 55%
    );
  }
  .landing__cuerpo {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 2;
    padding: clamp(1.25rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    max-width: 900px;
  }
  .landing__badge {
    display: inline-block;
    background: var(--color-acento);
    color: #000;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0.35em 0.8em;
    line-height: 1;
  }
  .landing__titulo {
    font-family: var(--fuente-titulos);
    font-weight: 400;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.1;
    margin: 0;
    color: #fff;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    overflow: hidden;
    padding-bottom: 0.08em;
  }
  .landing__autor {
    font-weight: 500;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  /* Hover: solo se amplía y oscurece la imagen */
  .landing:hover .landing__media img,
  .landing:focus-visible .landing__media img {
    transform: scale(1.06);
    filter: brightness(0.72);
  }
  .landing:focus-visible {
    outline: 3px solid var(--color-acento);
    outline-offset: 2px;
  }
</style>
