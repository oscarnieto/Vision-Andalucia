---
import { SECTORES } from '../lib/sectors';
---

<header class="cabecera">
  <div class="cabecera__linea">
    <div class="contenedor cabecera__barra">
      <a href="/" class="logo" aria-label="Visión Andalucía — inicio">
        <img
          src="/uploads/logo-vision-andalucia.svg"
          alt="Visión Andalucía"
          width="260"
          height="22"
        />
      </a>

      <button
        class="burger"
        type="button"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="menu-movil"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="cabecera__linea cabecera__linea--nav">
    <nav class="contenedor cabecera__nav" aria-label="Sectores">
      <ul>
        {
          SECTORES.map((s) => (
            <li>
              <a href={`/sector/${s.id}/`}>{s.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <nav id="menu-movil" class="menu-movil" aria-label="Sectores (móvil)" hidden>
    <ul>
      {
        SECTORES.map((s) => (
          <li>
            <a href={`/sector/${s.id}/`}>{s.label}</a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  .cabecera {
    background: var(--color-fondo);
  }
  .cabecera__linea {
    border-bottom: 1px solid var(--color-borde);
  }
  /* Solo la barra del logo va en amarillo; el menú de sectores queda blanco */
  .cabecera__linea:not(.cabecera__linea--nav) {
    background: #feeb14;
  }

  .cabecera__barra {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    min-height: 60px;
  }

  /* ---- Logo (wordmark VISIÓN | ANDALUCÍA) ---- */
  .logo {
    display: inline-flex;
    align-items: center;
    line-height: 0;
  }
  .logo img {
    height: clamp(18px, 4.5vw, 24px);
    width: auto;
  }

  /* ---- Barra de sectores (desktop) ---- */
  .cabecera__linea--nav {
    display: none;
  }
  .cabecera__nav ul {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.75rem;
    list-style: none;
    margin: 0;
    padding: 0.7rem 0;
  }
  .cabecera__nav a {
    position: relative;
    font-size: 0.8rem;
    color: var(--color-texto);
    padding-bottom: 2px;
  }
  /* Efecto hover: subrayado que crece desde el centro */
  .cabecera__nav a::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 0;
    height: 1.5px;
    background: var(--color-texto);
    transition:
      width 0.28s ease,
      left 0.28s ease;
  }
  .cabecera__nav a:hover::after,
  .cabecera__nav a:focus-visible::after {
    left: 0;
    width: 100%;
  }

  /* ---- Botón hamburguesa ---- */
  .burger {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 30px;
    height: 24px;
    padding: 0;
    background: none;
    border: 0;
    cursor: pointer;
  }
  .burger span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--color-texto);
    transition: transform 0.3s ease, opacity 0.2s ease;
  }
  .burger[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .burger[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .burger[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ---- Menú móvil desplegable ---- */
  .menu-movil {
    border-bottom: 1px solid var(--color-borde);
  }
  .menu-movil[hidden] {
    display: none;
  }
  .menu-movil ul {
    list-style: none;
    margin: 0;
    padding: 0.5rem var(--margen-lateral) 1rem;
  }
  .menu-movil li {
    border-top: 1px solid var(--color-borde-suave);
  }
  .menu-movil li:first-child {
    border-top: 0;
  }
  .menu-movil a {
    display: block;
    padding: 0.85rem 0;
    font-size: 0.95rem;
  }

  /* En pantallas grandes: barra de sectores visible, hamburguesa oculta */
  @media (min-width: 1024px) {
    .cabecera__linea--nav {
      display: block;
    }
    .burger {
      display: none;
    }
    .menu-movil {
      display: none !important;
    }
  }
</style>

<script>
  const burger = document.querySelector<HTMLButtonElement>('.burger');
  const menu = document.getElementById('menu-movil');

  burger?.addEventListener('click', () => {
    const abierto = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!abierto));
    burger.setAttribute('aria-label', abierto ? 'Abrir menú' : 'Cerrar menú');
    if (menu) menu.hidden = abierto;
  });
</script>
