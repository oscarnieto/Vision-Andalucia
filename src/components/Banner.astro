---
interface Props {
  imagen: string;
  imagenAlt?: string;
  texto: string;
  botonTexto: string;
  botonUrl: string;
}

const { imagen, imagenAlt = '', texto, botonTexto, botonUrl } = Astro.props;
const externo = /^https?:\/\//.test(botonUrl);
---

<section class="banner full-bleed" data-reveal>
  <img class="banner__img" src={imagen} alt={imagenAlt} />
  <div class="banner__grad" aria-hidden="true"></div>
  <div class="banner__contenido contenedor">
    <p class="banner__texto">{texto}</p>
    <a
      class="banner__btn"
      href={botonUrl}
      {...externo ? { target: '_blank', rel: 'noopener' } : {}}
    >
      {botonTexto}
    </a>
  </div>
</section>

<style>
  .banner {
    position: relative;
    height: clamp(340px, 32vw, 462px);
    overflow: hidden;
    isolation: isolate;
    color: #fff;
    margin-block: clamp(2.5rem, 5vw, 4rem);
  }
  .banner__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .banner__grad {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 38%,
      rgba(0, 0, 0, 0.87) 91%
    );
  }
  .banner__contenido {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 2;
    padding-bottom: clamp(1.75rem, 3vw, 2.75rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }
  .banner__texto {
    font-family: var(--fuente-titulos);
    font-weight: 400;
    font-size: clamp(1.1rem, 1.8vw, 1.375rem);
    line-height: 1.25;
    margin: 0;
    max-width: 750px;
  }
  .banner__btn {
    display: inline-block;
    background: var(--color-acento);
    color: #000;
    font-family: var(--fuente-texto);
    font-weight: 600;
    font-size: 1rem;
    padding: 0.55rem 1.75rem;
    transition: filter 0.2s ease;
  }
  .banner__btn:hover {
    filter: brightness(0.92);
  }
</style>
