---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoticiaCard from '../../components/NoticiaCard.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import { getNoticias, getRelacionadas } from '../../lib/noticias';
import { sectorLabel } from '../../lib/sectors';

export async function getStaticPaths() {
  const noticias = await getNoticias();
  return noticias.map((noticia) => ({
    params: { slug: noticia.slug },
    props: { noticia },
  }));
}

const { noticia } = Astro.props;
const { data } = noticia;
const { Content } = await noticia.render();
const relacionadas = await getRelacionadas(noticia, 6);

const etiqueta = (data.categoria ?? sectorLabel(data.sector)).toUpperCase();

// Fecha con el formato del diseño: "1 Julio 2026"
const fechaLegible = (() => {
  const d = data.fecha;
  const mes = new Intl.DateTimeFormat('es-ES', { month: 'long' }).format(d);
  const mesCap = mes.charAt(0).toUpperCase() + mes.slice(1);
  return `${d.getDate()} ${mesCap} ${d.getFullYear()}`;
})();
---

<BaseLayout titulo={data.titulo} descripcion={data.resumen} tipo="article" imagen={data.imagen}>
  <article class="entrada">
    <!-- Cabecera centrada -->
    <header class="entrada__head contenedor">
      <span class="tag" data-reveal>{etiqueta}</span>

      <h1 class="entrada__titulo" data-reveal style="--reveal-delay:80ms">
        {data.titulo}
      </h1>

      <div class="entrada__autor" data-reveal style="--reveal-delay:160ms">
        <p class="entrada__autor-nombre">{data.autor}</p>
        {data.autorCargo && <p class="entrada__autor-cargo">{data.autorCargo}</p>}
      </div>

      <time class="entrada__fecha" datetime={data.fecha.toISOString()} data-reveal style="--reveal-delay:220ms">
        {fechaLegible}
      </time>
    </header>

    <!-- Imagen de cabecera a todo el ancho -->
    {
      data.imagen ? (
        <figure class="entrada__portada full-bleed" data-reveal>
          <img src={data.imagen} alt={data.imagenAlt} />
        </figure>
      ) : (
        <div class="entrada__portada entrada__portada--vacia full-bleed" data-reveal aria-hidden="true" />
      )
    }

    <!-- Cuerpo -->
    <div class="entrada__cuerpo contenedor">
      <p class="entrada__lead" data-reveal>{data.resumen}</p>

      {data.video && (
        <div data-reveal>
          <VideoEmbed url={data.video} titulo={data.titulo} />
        </div>
      )}

      <div class="prosa" data-reveal>
        <Content />
      </div>

      {
        data.tags.length > 0 && (
          <ul class="entrada__tags" data-reveal>
            {data.tags.map((t) => (
              <li>
                <a href={`/tag/${encodeURIComponent(t)}/`}>#{t}</a>
              </li>
            ))}
          </ul>
        )
      }
    </div>

    <!-- Noticias relacionadas -->
    {
      relacionadas.length > 0 && (
        <section class="relacionadas contenedor" aria-labelledby="rel-titulo">
          <h2 id="rel-titulo" class="relacionadas__titulo" data-reveal>
            Noticias relacionadas
          </h2>
          <div class="relacionadas__grid">
            {relacionadas.map((n, i) => (
              <div data-reveal style={`--reveal-delay:${i * 90}ms`}>
                <NoticiaCard noticia={n} />
              </div>
            ))}
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .entrada__head {
    text-align: center;
    padding-top: clamp(2rem, 5vw, 3.75rem);
  }

  /* Tag amarillo */
  .tag {
    display: inline-block;
    background: var(--color-acento);
    color: var(--color-texto);
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    padding: 0.35em 0.9em;
    line-height: 1;
  }

  .entrada__titulo {
    font-family: var(--fuente-titulos);
    font-weight: 400;
    font-size: clamp(1.9rem, 5vw, 3.125rem);
    line-height: 1.05;
    max-width: 966px;
    margin: 1.5rem auto 0;
  }

  .entrada__autor {
    margin-top: clamp(1.75rem, 4vw, 2.5rem);
  }
  .entrada__autor-nombre {
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0;
  }
  .entrada__autor-cargo {
    font-size: 0.8125rem;
    margin: 0.15rem 0 0;
  }

  .entrada__fecha {
    display: block;
    margin-top: 0.75rem;
    font-weight: 500;
    font-size: 0.75rem;
  }

  /* Imagen de cabecera full-bleed */
  .entrada__portada {
    margin: clamp(2rem, 4vw, 2.75rem) 0 0;
    height: clamp(240px, 40vw, 578px);
    overflow: hidden;
  }
  .entrada__portada img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .entrada__portada--vacia {
    background: var(--color-card);
  }

  /* Cuerpo */
  .entrada__cuerpo {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    max-width: calc(1140px + var(--margen-lateral) * 2);
  }
  .entrada__lead {
    font-family: var(--fuente-texto);
    font-weight: 700;
    font-size: clamp(1.35rem, 3vw, 2rem);
    line-height: 1.35;
    margin: 0 0 1.5rem;
  }

  .prosa {
    font-size: 1rem;
    line-height: 1.7;
  }
  .prosa :global(p) {
    margin: 0 0 1.2rem;
  }
  .prosa :global(h2) {
    font-family: var(--fuente-texto);
    font-weight: 700;
    font-size: 1.15rem;
    margin: 2rem 0 0.4rem;
  }
  .prosa :global(h3) {
    font-family: var(--fuente-texto);
    font-weight: 700;
    font-size: 1.05rem;
    margin: 1.6rem 0 0.4rem;
  }
  .prosa :global(strong) {
    font-weight: 700;
  }
  .prosa :global(img) {
    margin: 1.5rem 0;
  }
  .prosa :global(blockquote) {
    border-left: 3px solid var(--color-acento);
    margin: 1.5rem 0;
    padding-left: 1rem;
    font-style: italic;
  }

  .entrada__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 2.5rem 0 0;
  }
  .entrada__tags a {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--color-borde-suave);
    border-radius: 999px;
    font-size: 0.8rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .entrada__tags a:hover {
    border-color: var(--color-texto);
    background: var(--color-superficie);
  }

  /* Relacionadas */
  .relacionadas {
    margin-top: clamp(3rem, 6vw, 5rem);
  }
  .relacionadas__titulo {
    font-family: var(--fuente-texto);
    font-weight: 600;
    font-size: 1.375rem;
    margin: 0 0 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-borde);
  }
  .relacionadas__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  @media (max-width: 900px) {
    .relacionadas__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .relacionadas__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
