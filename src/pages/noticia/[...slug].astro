---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoticiaCard from '../../components/NoticiaCard.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import FechaNoticia from '../../components/FechaNoticia.astro';
import { getNoticias, getRelacionadas } from '../../lib/noticias';
import { sectorLabel } from '../../lib/sectors';

export async function getStaticPaths() {
  const noticias = await getNoticias();
  return noticias.map((noticia) => ({
    params: { slug: noticia.slug },
    props: { noticia },
  }));
}

const { noticia } = Astro.props;
const { data } = noticia;
const { Content } = await noticia.render();
const relacionadas = await getRelacionadas(noticia, 3);
---

<BaseLayout
  titulo={data.titulo}
  descripcion={data.resumen}
  tipo="article"
>
  <article class="articulo">
    <header class="articulo__cabecera">
      <a href={`/sector/${data.sector}/`} class="articulo__sector">
        {sectorLabel(data.sector)}
      </a>
      <h1 class="articulo__titulo">{data.titulo}</h1>
      <p class="articulo__resumen">{data.resumen}</p>
      <div class="articulo__meta">
        <span>{data.autor}</span>
        <FechaNoticia fecha={data.fecha} />
        {
          data.fechaActualizacion && (
            <FechaNoticia fecha={data.fechaActualizacion} prefijo="Act." />
          )
        }
      </div>
    </header>

    {
      data.imagen && (
        <figure class="articulo__portada">
          <img src={data.imagen} alt={data.imagenAlt} />
          {data.imagenAlt && <figcaption>{data.imagenAlt}</figcaption>}
        </figure>
      )
    }

    {data.video && <VideoEmbed url={data.video} titulo={data.titulo} />}

    <div class="articulo__cuerpo prosa">
      <Content />
    </div>

    {
      data.tags.length > 0 && (
        <ul class="articulo__tags" aria-label="Etiquetas">
          {data.tags.map((t) => (
            <li>
              <a href={`/tag/${encodeURIComponent(t)}/`}>#{t}</a>
            </li>
          ))}
        </ul>
      )
    }
  </article>

  {
    relacionadas.length > 0 && (
      <section class="seccion" aria-labelledby="titulo-relacionadas">
        <div class="seccion__titulo">
          <h2 id="titulo-relacionadas">Noticias relacionadas</h2>
        </div>
        <div class="grid-noticias">
          {relacionadas.map((n) => (
            <NoticiaCard noticia={n} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .articulo {
    max-width: 760px;
    margin-inline: auto;
    margin-block: 2rem;
  }
  .articulo__sector {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primario);
  }
  .articulo__titulo {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    margin: 0.5rem 0;
  }
  .articulo__resumen {
    font-size: 1.2rem;
    color: var(--color-texto-suave);
    margin: 0 0 1rem;
  }
  .articulo__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;
    align-items: center;
    padding-block: 1rem;
    border-top: 1px solid var(--color-borde);
    border-bottom: 1px solid var(--color-borde);
    font-size: 0.85rem;
    color: var(--color-texto-suave);
  }
  .articulo__portada {
    margin: 1.5rem 0;
  }
  .articulo__portada :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radio);
  }
  .articulo__portada figcaption {
    font-size: 0.8rem;
    color: var(--color-texto-suave);
    margin-top: 0.5rem;
  }
  .articulo__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
  }
  .articulo__tags a {
    display: inline-block;
    padding: 0.25rem 0.7rem;
    background: var(--color-superficie);
    border-radius: 999px;
    font-size: 0.85rem;
  }
  .articulo__tags a:hover {
    text-decoration: none;
    background: var(--color-borde);
  }

  /* Tipografía del cuerpo del artículo */
  .prosa {
    font-size: 1.1rem;
    line-height: 1.75;
  }
  .prosa :global(h2) {
    margin-top: 2rem;
    font-size: 1.6rem;
  }
  .prosa :global(h3) {
    margin-top: 1.5rem;
    font-size: 1.3rem;
  }
  .prosa :global(img) {
    border-radius: var(--radio);
    margin-block: 1.5rem;
  }
  .prosa :global(blockquote) {
    border-left: 4px solid var(--color-primario);
    margin-inline: 0;
    padding-left: 1rem;
    color: var(--color-texto-suave);
    font-style: italic;
  }
  .prosa :global(figure) {
    margin-inline: 0;
  }
</style>
