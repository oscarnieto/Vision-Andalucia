---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NoticiaCard from '../components/NoticiaCard.astro';
import CardDestacada from '../components/CardDestacada.astro';
import LandingCard from '../components/LandingCard.astro';
import Banner from '../components/Banner.astro';
import { SECTORES } from '../lib/sectors';
import { getNoticias, getDestacadas, getPorSector } from '../lib/noticias';
import banner from '../data/banner.json';

// --- Landings publicadas (se muestran grandes al inicio) ---
const landings = (
  await getCollection('paginas', (p) =>
    import.meta.env.PROD ? !p.data.borrador : true,
  )
).sort(
  (a, b) =>
    (b.data.fecha?.valueOf() ?? 0) - (a.data.fecha?.valueOf() ?? 0),
);

// --- Últimas novedades ---
const destacada = (await getDestacadas(1))[0]; // se oculta si no hay ninguna
const ultimas = (await getNoticias())
  .filter((n) => n.id !== destacada?.id)
  .slice(0, 3);

// --- Bloques por sector (solo los que tienen noticias) ---
const bloquesSector = (
  await Promise.all(
    SECTORES.map(async (s) => ({
      sector: s,
      noticias: await getPorSector(s.id, 3),
    })),
  )
).filter((b) => b.noticias.length > 0);
---

<BaseLayout titulo="Visión Andalucía — Actualidad inmobiliaria">
  {landings.length > 0 && (
    <div class="contenedor landings">
      {landings.map((p) => (
        <div class="landings__item" data-reveal>
          <LandingCard pagina={p} />
        </div>
      ))}
    </div>
  )}

  <div class="contenedor">
    <!-- Últimas novedades -->
    <section class="seccion" aria-labelledby="novedades">
      <header class="seccion__cab" data-reveal>
        <h2 id="novedades">Últimas novedades</h2>
      </header>

      {destacada && (
        <div class="seccion__destacada" data-reveal>
          <CardDestacada noticia={destacada} />
        </div>
      )}

      {ultimas.length > 0 ? (
        <div class="rejilla">
          {ultimas.map((n, i) => (
            <div data-reveal style={`--reveal-delay:${(i % 3) * 90}ms`}>
              <NoticiaCard noticia={n} />
            </div>
          ))}
        </div>
      ) : (
        <p data-reveal>
          Aún no hay noticias publicadas. Añade la primera desde el panel{' '}
          <a href="/admin/">/admin</a>.
        </p>
      )}
    </section>
  </div>

  <!-- Bloques por sector (+ banner tras el primero) -->
  {bloquesSector.map(({ sector, noticias }, idx) => (
    <>
      <div class="contenedor">
        <section class="seccion" aria-labelledby={`s-${sector.id}`}>
          <header class="seccion__cab" data-reveal>
            <h2 id={`s-${sector.id}`}>{sector.label}</h2>
            <a class="seccion__ver" href={`/sector/${sector.id}/`}>ver todo</a>
          </header>
          <div class="rejilla">
            {noticias.map((n, i) => (
              <div data-reveal style={`--reveal-delay:${(i % 3) * 90}ms`}>
                <NoticiaCard noticia={n} />
              </div>
            ))}
          </div>
        </section>
      </div>

      {idx === 0 && banner.activo && (
        <Banner
          imagen={banner.imagen}
          imagenAlt={banner.imagenAlt}
          texto={banner.texto}
          botonTexto={banner.botonTexto}
          botonUrl={banner.botonUrl}
        />
      )}
    </>
  ))}
</BaseLayout>

<style>
  .landings {
    margin-top: clamp(2rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }
  .seccion {
    margin-block: clamp(2.5rem, 5vw, 3.5rem);
  }
  .seccion__cab {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-borde);
  }
  .seccion__cab h2 {
    font-family: var(--fuente-texto);
    font-weight: 600;
    font-size: 1.375rem;
    margin: 0;
  }
  .seccion__ver {
    font-size: 0.9rem;
    color: var(--color-texto-suave);
  }
  .seccion__ver:hover {
    color: var(--color-texto);
    text-decoration: underline;
  }
  .seccion__destacada {
    margin-bottom: 30px;
  }
  .rejilla {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  @media (max-width: 900px) {
    .rejilla {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .rejilla {
      grid-template-columns: 1fr;
    }
  }
</style>
