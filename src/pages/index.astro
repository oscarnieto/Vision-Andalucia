---
import BaseLayout from '../layouts/BaseLayout.astro';
import NoticiaCard from '../components/NoticiaCard.astro';
import { SECTORES } from '../lib/sectors';
import { getUltimas, getPorSector } from '../lib/noticias';

const ultimas = await getUltimas(6);

const bloquesSector = await Promise.all(
  SECTORES.map(async (s) => ({
    sector: s,
    noticias: await getPorSector(s.id, 3),
  })),
);
const sectoresConNoticias = bloquesSector.filter((b) => b.noticias.length > 0);
---

<BaseLayout titulo="Visión Andalucía — Actualidad inmobiliaria">
  <div class="contenedor home">
    <section class="bloque" aria-labelledby="ultimas">
      <div class="bloque__cabecera" data-reveal>
        <h2 id="ultimas">Últimas novedades</h2>
        <a href="/rss.xml">Suscribirse (RSS)</a>
      </div>
      {
        ultimas.length > 0 ? (
          <div class="rejilla">
            {ultimas.map((n, i) => (
              <div data-reveal style={`--reveal-delay:${(i % 3) * 90}ms`}>
                <NoticiaCard noticia={n} />
              </div>
            ))}
          </div>
        ) : (
          <p data-reveal>
            Aún no hay noticias publicadas. Añade la primera desde el panel{' '}
            <a href="/admin/">/admin</a>.
          </p>
        )
      }
    </section>

    {
      sectoresConNoticias.map(({ sector, noticias }) => (
        <section class="bloque" aria-labelledby={`s-${sector.id}`}>
          <div class="bloque__cabecera" data-reveal>
            <h2 id={`s-${sector.id}`}>{sector.label}</h2>
            <a href={`/sector/${sector.id}/`}>Ver todo</a>
          </div>
          <div class="rejilla">
            {noticias.map((n, i) => (
              <div data-reveal style={`--reveal-delay:${(i % 3) * 90}ms`}>
                <NoticiaCard noticia={n} />
              </div>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>

<style>
  .home {
    padding-top: clamp(2rem, 5vw, 3rem);
  }
  .bloque {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .bloque__cabecera {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-borde);
  }
  .bloque__cabecera h2 {
    font-family: var(--fuente-texto);
    font-weight: 600;
    font-size: 1.375rem;
    margin: 0;
  }
  .bloque__cabecera a {
    font-size: 0.85rem;
  }
  .bloque__cabecera a:hover {
    text-decoration: underline;
  }
  .rejilla {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  @media (max-width: 900px) {
    .rejilla {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .rejilla {
      grid-template-columns: 1fr;
    }
  }
</style>
