---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoticiaCard from '../../components/NoticiaCard.astro';
import { getNoticias } from '../../lib/noticias';

export async function getStaticPaths() {
  const noticias = await getNoticias();
  const tags = new Map<string, string>(); // slug -> etiqueta original
  for (const n of noticias) {
    for (const t of n.data.tags) tags.set(t, t);
  }
  return [...tags.keys()].map((t) => ({
    params: { tag: t },
    props: { tag: t },
  }));
}

const { tag } = Astro.props;
const noticias = (await getNoticias()).filter((n) =>
  n.data.tags.includes(tag),
);
---

<BaseLayout
  titulo={`#${tag}`}
  descripcion={`Noticias etiquetadas con ${tag} en Vision Andalucia.`}
>
  <div class="seccion">
    <div class="seccion__titulo">
      <h2>#{tag}</h2>
    </div>
    <div class="grid-noticias">
      {noticias.map((n) => <NoticiaCard noticia={n} />)}
    </div>
  </div>
</BaseLayout>
