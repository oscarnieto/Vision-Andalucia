---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  titulo: string;
  descripcion?: string;
  imagen?: string;
  tipo?: 'website' | 'article';
}

const {
  titulo,
  descripcion = 'Actualidad y análisis del mercado inmobiliario en Andalucía.',
  imagen,
  tipo = 'website',
} = Astro.props;

const tituloCompleto = titulo.includes('Visión Andalucía')
  ? titulo
  : `${titulo} · Visión Andalucía`;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const imagenAbs = imagen ? new URL(imagen, Astro.site).href : undefined;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Visión Andalucía"
      href="/rss.xml"
    />

    <!-- Tipografías del diseño: Playfair Display + Montserrat -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&display=swap"
    />

    <title>{tituloCompleto}</title>
    <meta name="description" content={descripcion} />

    <!-- Open Graph -->
    <meta property="og:type" content={tipo} />
    <meta property="og:title" content={tituloCompleto} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:url" content={canonical} />
    {imagenAbs && <meta property="og:image" content={imagenAbs} />}
    <meta name="twitter:card" content="summary_large_image" />

    <slot name="head" />
  </head>
  <body>
    <Header />
    <main id="contenido">
      <slot />
    </main>
    <Footer />

    <!-- Animaciones de aparición al hacer scroll (IntersectionObserver) -->
    <script>
      const reveal = () => {
        const els = document.querySelectorAll<HTMLElement>('[data-reveal]');
        const reduce = window.matchMedia(
          '(prefers-reduced-motion: reduce)',
        ).matches;

        if (reduce || !('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }

        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
        );

        els.forEach((el) => io.observe(el));
      };

      // Se ejecuta al cargar y en navegaciones internas de Astro.
      reveal();
      document.addEventListener('astro:after-swap', reveal);
    </script>
  </body>
</html>
