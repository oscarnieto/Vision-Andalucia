---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  titulo: string;
  descripcion?: string;
  imagen?: string;
  tipo?: 'website' | 'article';
}

const {
  titulo,
  descripcion = 'Noticias y actualidad de los sectores clave de Andalucía.',
  imagen,
  tipo = 'website',
} = Astro.props;

const tituloCompleto = titulo.includes('Vision Andalucia')
  ? titulo
  : `${titulo} · Vision Andalucia`;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const imagenAbs = imagen ? new URL(imagen, Astro.site).href : undefined;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Vision Andalucia"
      href="/rss.xml"
    />

    <title>{tituloCompleto}</title>
    <meta name="description" content={descripcion} />

    <!-- Open Graph -->
    <meta property="og:type" content={tipo} />
    <meta property="og:title" content={tituloCompleto} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:url" content={canonical} />
    {imagenAbs && <meta property="og:image" content={imagenAbs} />}
    <meta name="twitter:card" content="summary_large_image" />

    <slot name="head" />
  </head>
  <body>
    <Header />
    <main class="contenedor">
      <slot />
    </main>
    <Footer />
  </body>
</html>
